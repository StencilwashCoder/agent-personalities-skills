# MCP Server Validator - Environment Variables
# Copy this file to .env and fill in your values for local development/testing

# GitHub Configuration
GITHUB_TOKEN=ghp_your_token_here

# MCP Server Configuration Examples
# Add your MCP server tokens here for testing
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_key_here

# Test Configuration
TEST_MCP_CONFIG_PATH=./test/fixtures/mcp.json
TEST_TIMEOUT_MS=30000

# Debug Mode
DEBUG=false
VERBOSE=false
