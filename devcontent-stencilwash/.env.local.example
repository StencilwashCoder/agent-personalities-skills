# Stencilwash Content Agency - Environment Variables

# Stripe Configuration
# Get these from your Stripe Dashboard: https://dashboard.stripe.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_starter_xxx
NEXT_PUBLIC_STRIPE_GROWTH_PRICE_ID=price_growth_xxx
NEXT_PUBLIC_STRIPE_SCALE_PRICE_ID=price_scale_xxx

# Stripe Checkout Direct Links (for MVP - easier than API integration)
# Create these in Stripe: Products > [Product] > Checkout Link
NEXT_PUBLIC_STRIPE_STARTER_LINK=https://buy.stripe.com/test_starter_link
NEXT_PUBLIC_STRIPE_GROWTH_LINK=https://buy.stripe.com/test_growth_link
NEXT_PUBLIC_STRIPE_SCALE_LINK=https://buy.stripe.com/test_scale_link

# App Config
NEXT_PUBLIC_URL=https://devcontent.stencilwash.com

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
